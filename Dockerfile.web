# Сборка фронтенда: Debian (glibc), т.к. в Alpine npm не ставит optional @rollup/rollup-linux-x64-musl (баг npm)
FROM node:20-bookworm-slim AS base
FROM base AS deps
WORKDIR /app
COPY package.json package-lock.json* ./
COPY apps/web/package.json apps/web/
RUN npm ci
# npm часто не ставит optional native Rollup (баг npm/cli#4828) — ставим вручную в workspace
RUN cd apps/web && npm install @rollup/rollup-linux-x64-gnu --no-save

FROM base AS frontend-builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY package.json package-lock.json* ./
COPY apps/web ./apps/web
COPY --from=deps /app/apps/web/node_modules ./apps/web/node_modules
RUN npm run build -w web

# Стадия 2: nginx раздаёт собранную статику и проксирует /api к контейнеру api
FROM nginx:alpine
COPY --from=frontend-builder /app/apps/web/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]