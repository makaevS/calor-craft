# Копируй в .env.prod и подставь свои значения.
# Используется для npm run start (production). Порты отличаются от dev, чтобы можно было запускать оба режима сразу.
POSTGRES_USER=example_user
POSTGRES_PASSWORD=example_password
POSTGRES_DB=calor_craft_prod

# API слушает на 3001 (dev использует 3000)
PORT=3001

# Postgres для prod на порту 5433 (dev — 5432)
DATABASE_URL=postgresql://example_user:example_password@localhost:5433/calor_craft_prod?schema=public
