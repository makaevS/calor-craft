# Копируй в .env.prod и подставь свои значения.
# Используется для npm run start (production).
POSTGRES_USER=example_user
POSTGRES_PASSWORD=example_password
POSTGRES_DB=calor_craft_prod

# URL для API (тот же пользователь/пароль/БД, хост localhost)
DATABASE_URL=postgresql://example_user:example_password@localhost:5432/calor_craft_prod?schema=public
