# Копируй в .env.dev и подставь свои значения.
# Используется для npm run dev (разработка).
POSTGRES_USER=example_user
POSTGRES_PASSWORD=example_password
POSTGRES_DB=calor_craft_dev

# URL для API (тот же пользователь/пароль/БД, хост localhost)
DATABASE_URL=postgresql://example_user:example_password@localhost:5432/calor_craft_dev?schema=public

# JWT (обязательно). Секрет для access-токенов.
JWT_SECRET=your_secret_min_32_chars_long

# Опционально
# JWT_EXPIRES_IN=15m
# REFRESH_TOKEN_EXPIRES_IN=7d
