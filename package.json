{
  "name": "calor-craft",
  "version": "0.1.0",
  "private": true,
  "description": "Calorie tracking web app — food diary and product database",
  "license": "MIT",
  "author": "makaev.stepan@vk.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/makaevs/calor-craft.git"
  },
  "keywords": [
    "calories",
    "diet",
    "nutrition",
    "tracking"
  ],
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w apps/web",
    "dev:api": "npm run start:dev -w apps/api",
    "build:web": "npm run build -w apps/web",
    "build:api": "npm run build -w apps/api",
    "build": "npm run build:web && npm run build:api",
    "compose:up": "powershell -ExecutionPolicy Bypass -File ./build-and-up.ps1"
  },
  "engines": {
    "node": ">=18"
  }
}
